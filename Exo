connect = function(signal, fn)
    local conn = signal:Connect(function(...)
        local ok, err = pcall(fn, ...)
        if not ok then
            warn("[UiLibrary] signal error:", err)
        end
    end)
    table.insert(Library._connections, conn)
    return conn
end

function Library:_disconnectAll()
    for _, conn in ipairs(self._connections) do
        if conn and conn.Disconnect then
            pcall(function()
                conn:Disconnect()
            end)
        end
    end
    table.clear(self._connections)
end

function Library:GetFlag(flag, defaultValue)
    local v = self.Flags[flag]
    if v == nil then
        return defaultValue
    end
    return v
end

function Library:GetFlags(...)
    local out = {}
    local args = { ... }
    for i = 1, #args do
        out[i] = self.Flags[args[i]]
    end
    return table.unpack(out)
end

function Library:IsEnabled(flag)
    return self.Flags[flag] == true
end

function Library:_ensureFolder()
    if not FILE_API then
        return false, "file API unavailable"
    end
    local path = self.Config.Folder:gsub("\\", "/")
    local cur = ""
    for part in path:gmatch("[^/]+") do
        cur = (cur == "") and part or (cur .. "/" .. part)
        if not fsIsFolder(cur) then
            local ok, err = fsMakeFolder(cur)
            if not ok then
                return false, err or "failed to create folder"
            end
        end
    end
    return true
end

function Library:_configPath(profile)
    return string.format("%s/%s.json", self.Config.Folder, sanitizeName(profile or self.Config.Profile))
end

function Library:_snapshotFlags()
    local out = {}
    for flag, control in pairs(self._controls) do
        local isInternal = type(flag) == "string" and flag:sub(1, 10) == "__xero_ui_"
        if not isInternal and control and control.Value ~= nil then
            out[flag] = deepCopy(control.Value)
        end
    end
    for flag, value in pairs(self.Flags) do
        local isInternal = type(flag) == "string" and flag:sub(1, 10) == "__xero_ui_"
        if not isInternal and out[flag] == nil then
            out[flag] = deepCopy(value)
        end
    end
    return out
end

function Library:_snapshotToggleBinds()
    local out = {}
    for flag, control in pairs(self._controls) do
        local isInternal = type(flag) == "string" and flag:sub(1, 10) == "__xero_ui_"
        if not isInternal and control and control.Type == "Toggle" then
            local bindValue = control.KeybindValue
            if type(bindValue) == "string" and bindValue ~= "" then
                out[flag] = bindValue
            end
        end
    end
    return out
end

function Library:SaveConfig(profile)
    if not FILE_API then
        return false, "file API unavailable"
    end
    local ok, err = self:_ensureFolder()
    if not ok then
        return false, err
    end

    local data = {
        meta = {
            version = self.Version,
            placeId = game.PlaceId,
            userId = LocalPlayer and LocalPlayer.UserId or 0,
            savedAt = os.time(),
        },
        flags = self:_snapshotFlags(),
        toggleBinds = self:_snapshotToggleBinds(),
    }

    local okEncode, jsonOrErr = pcall(function()
        return HttpService:JSONEncode(data)
    end)
    if not okEncode then
        warn("[UiLibrary] config encode error:", jsonOrErr)
        return false, jsonOrErr
    end

    local okWrite, errWrite = fsWriteFile(self:_configPath(profile), jsonOrErr)
    if not okWrite then
        return false, errWrite or "write failed"
    end
    return true
end

function Library:LoadConfig(profile, silent)
    if not FILE_API then
        return false, "file API unavailable"
    end

    local path = self:_configPath(profile)
    if not fsIsFile(path) then
        return false, "config not found"
    end

    local okRead, contentOrErr = fsReadFile(path)
    if not okRead then
        return false, contentOrErr or "read failed"
    end

    local ok, decoded = pcall(function()
        return HttpService:JSONDecode(contentOrErr)
    end)
    if not ok or type(decoded) ~= "table" or type(decoded.flags) ~= "table" then
        return false, "invalid config"
    end

    self._loadingConfig = true
    for flag, value in pairs(decoded.flags) do
        local control = self._controls[flag]
        if control and control.SetValue then
            control:SetValue(value, false)
        else
            self.Flags[flag] = deepCopy(value)
            self._autoloadFlags = self._autoloadFlags or {}
            self._autoloadFlags[flag] = deepCopy(value)
        end
    end
    if type(decoded.toggleBinds) == "table" then
        local bindMap = decoded.toggleBinds
        for flag, control in pairs(self._controls) do
            if control and control.Type == "Toggle" and control.SetKeybind then
                control:SetKeybind(bindMap[flag], true)
            end
        end
        for flag, bindValue in pairs(bindMap) do
            local control = self._controls[flag]
            if not (control and control.Type == "Toggle" and control.SetKeybind) then
                self._autoloadToggleBinds = self._autoloadToggleBinds or {}
                self._autoloadToggleBinds[flag] = bindValue
            end
        end
    end
    self._loadingConfig = false

    if not silent then
        self:Notify("Loaded config: " .. tostring(profile or self.Config.Profile), 3)
    end
    return true
end

function Library:ListConfigs()
    if not FILE_API or type(listfiles) ~= "function" then
        return {}
    end
    local ok = self:_ensureFolder()
    if not ok then
        return {}
    end

    local out = {}
    local okList, filesOrErr = fsListFiles(self.Config.Folder)
    if not okList then
        return {}
    end

    for _, path in ipairs(filesOrErr) do
        local normalized = tostring(path):gsub("\\", "/")
        local name = normalized:match(".*/([^/]+)%.json$")
        if name then
            table.insert(out, name)
        end
    end
    table.sort(out)
    return out
end

function Library:_prepareAutoLoad()
    self._autoloadFlags = nil
    self._autoloadToggleBinds = nil
    if not self.Config.AutoLoad or not FILE_API then
        return
    end

    local path = self:_configPath(self.Config.Profile)
    if not fsIsFile(path) then
        return
    end

    local okRead, content = fsReadFile(path)
    if not okRead then
        return
    end

    local ok, decoded = pcall(function()
        return HttpService:JSONDecode(content)
    end)
    if ok and type(decoded) == "table" and type(decoded.flags) == "table" then
        self._autoloadFlags = decoded.flags
        if type(decoded.toggleBinds) == "table" then
            self._autoloadToggleBinds = decoded.toggleBinds
        end
    end
end

function Library:DeleteConfig(profile)
    if not FILE_API then
        return false, "file API unavailable"
    end

    local path = self:_configPath(profile)
    if not fsIsFile(path) then
        return false, "config not found"
    end

    local okDelete, errDelete = fsDeleteFile(path)
    if not okDelete then
        return false, errDelete or "delete failed"
    end
    return true
end

function Library:_initialValue(flag, fallback)
    if self._autoloadFlags and self._autoloadFlags[flag] ~= nil then
        return deepCopy(self._autoloadFlags[flag]), true
    end
    if self.Flags[flag] ~= nil then
        return deepCopy(self.Flags[flag]), false
    end
    return deepCopy(fallback), false
end

function Library:_initialToggleBind(flag, fallback)
    if self._autoloadToggleBinds and self._autoloadToggleBinds[flag] ~= nil then
        return deepCopy(self._autoloadToggleBinds[flag]), true
    end
    return deepCopy(fallback), false
end

function Library:_queueAutoSave()
    if not self.Config.AutoSave or self._loadingConfig then
        return
    end
    if self._autosaveQueued then
        return
    end

    self._autosaveQueued = true
    task.delay(self.Config.AutoSaveDelay, function()
        self._autosaveQueued = false
        self:SaveConfig(self.Config.Profile)
    end)
end

function Library:_flagChanged(flag, value, silent)
    self.Flags[flag] = deepCopy(value)
    if not silent then
        self:_queueAutoSave()
    end
end

function Library:Notify(message, duration)
    duration = duration or 3
    if not self._notifyHolder then
        warn("[UiLibrary]", message)
        return
    end

    local toast = create("Frame", {
        BackgroundColor3 = self.Theme.Surface,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 0),
    }, self._notifyHolder)
    corner(toast, 10)
    stroke(toast, self.Theme.Stroke, 0.36, 1.15)
    gradient(toast, {
        self.Theme.Surface,
        self.Theme.SurfaceAlt,
    }, 12)

    local accentBar = create("Frame", {
        Size = UDim2.new(0, 3, 1, -8),
        Position = UDim2.new(0, 4, 0, 4),
        BackgroundColor3 = self.Theme.Accent,
        BorderSizePixel = 0,
    }, toast)
    corner(accentBar, 999)

    local label = create("TextLabel", {
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 13, 0, 6),
        Size = UDim2.new(1, -21, 1, -12),
        TextWrapped = true,
        TextXAlignment = Enum.TextXAlignment.Left,
        Text = tostring(message),
        TextColor3 = self.Theme.Text,
        Font = Enum.Font.GothamSemibold,
        TextSize = 14,
    }, toast)

    task.defer(function()
        local h = math.max(38, label.TextBounds.Y + 14)
        TweenService:Create(toast, TweenInfo.new(0.16, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Size = UDim2.new(1, 0, 0, h),
        }):Play()
    end)

    task.delay(duration, function()
        if not toast.Parent then
            return
        end
        local tween = TweenService:Create(toast, TweenInfo.new(0.16, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
            Size = UDim2.new(1, 0, 0, 0),
            BackgroundTransparency = 1,
        })
        tween:Play()
        tween.Completed:Wait()
        toast:Destroy()
    end)
end

local function makeDraggable(dragArea, target)
    local dragging = false
    local dragInput
    local startPos
    local startInput

    connect(dragArea.InputBegan, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            startPos = target.Position
            startInput = input.Position

            local c
            c = input.Changed:Connect(function()
                local ok, err = pcall(function()
                    if input.UserInputState == Enum.UserInputState.End then
                        dragging = false
                        dragInput = nil
                        if c then
                            c:Disconnect()
                        end
                    end
                end)
                if not ok then
                    warn("[UiLibrary] signal error:", err)
                end
            end)
            table.insert(Library._connections, c)
        end
    end)

    connect(dragArea.InputChanged, function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    connect(UserInputService.InputChanged, function(input)
        if dragging and input == dragInput and startPos and startInput then
            local delta = input.Position - startInput
            local nextOffsetX = startPos.X.Offset + delta.X
            local nextOffsetY = startPos.Y.Offset + delta.Y

            local parent = target.Parent
            if parent and parent:IsA("GuiObject") then
                local parentSize = parent.AbsoluteSize
                local targetSize = target.AbsoluteSize
                local margin = 8

                local baseAbsX = startPos.X.Scale * parentSize.X
                local baseAbsY = startPos.Y.Scale * parentSize.Y
                local nextAbsX = baseAbsX + nextOffsetX
                local nextAbsY = baseAbsY + nextOffsetY

                local minAbsX = (target.AnchorPoint.X * targetSize.X) + margin
                local maxAbsX = parentSize.X - ((1 - target.AnchorPoint.X) * targetSize.X) - margin
                local minAbsY = (target.AnchorPoint.Y * targetSize.Y) + margin
                local maxAbsY = parentSize.Y - ((1 - target.AnchorPoint.Y) * targetSize.Y) - margin

                if maxAbsX < minAbsX then
                    maxAbsX = minAbsX
                end
                if maxAbsY < minAbsY then
                    maxAbsY = minAbsY
                end

                nextAbsX = clamp(nextAbsX, minAbsX, maxAbsX)
                nextAbsY = clamp(nextAbsY, minAbsY, maxAbsY)
                nextOffsetX = nextAbsX - baseAbsX
                nextOffsetY = nextAbsY - baseAbsY
            end

            target.Position = UDim2.new(startPos.X.Scale, nextOffsetX, startPos.Y.Scale, nextOffsetY)
        end
    end)
end

local function contains(tbl, item)
    for _, v in ipairs(tbl) do
        if v == item then
            return true
        end
    end
    return false
end

local function orderedSelected(values, selected)
    local out = {}
    for _, v in ipairs(values) do
        if selected[v] then
            table.insert(out, v)
        end
    end
    return out
end

local function pointInGui(guiObject, screenPos)
    if typeof(guiObject) ~= "Instance" or not guiObject:IsA("GuiObject") then
        return false
    end
    if not guiObject.Visible then
        return false
    end
    local pos = guiObject.AbsolutePosition
    local size = guiObject.AbsoluteSize
    local x = screenPos.X
    local y = screenPos.Y
    return x >= pos.X and x <= (pos.X + size.X) and y >= pos.Y and y <= (pos.Y + size.Y)
end

