                    return self
                end

                local function updateBindText()
                    if obj._listening then
                        bindButton.Text = "Press key..."
                    elseif obj.Value == "" then
                        bindButton.Text = "None"
                    else
                        bindButton.Text = obj.Value
                    end
                end

