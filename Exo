local function detectBootstrapSource()
    if type(env.__XERO_UI_SOURCE_CODE) == "string" and #env.__XERO_UI_SOURCE_CODE > 0 then
        return {
            Kind = "code",
            Value = env.__XERO_UI_SOURCE_CODE,
        }
    end

    if FILE_API and type(env.__XERO_UI_SOURCE_PATH) == "string" and fsIsFile(env.__XERO_UI_SOURCE_PATH) then
        return {
            Kind = "path",
            Value = env.__XERO_UI_SOURCE_PATH,
        }
    end

    local ok, source = pcall(debug.info, 1, "s")
    if ok and type(source) == "string" then
        local cleaned = source
        if cleaned:sub(1, 1) == "@" then
            cleaned = cleaned:sub(2)
        end
        cleaned = cleaned:gsub("^=", "")
        if FILE_API and fsIsFile(cleaned) then
            return {
                Kind = "path",
                Value = cleaned,
            }
        end
    end

    return nil
end

local function tryBootstrapOnActor()
    if not ACTOR_BOOTSTRAP_ENABLED then
        return false
    end
    if env.__XERO_UI_ACTOR_RUNNING == true then
        return false
    end
    if type(getactors) ~= "function" or type(run_on_actor) ~= "function" then
        return false
    end

    local okActors, actors = pcall(getactors)
    if not okActors or type(actors) ~= "table" or #actors == 0 then
        return false
    end

    local actor = actors[1]
    for _, candidate in ipairs(actors) do
        if typeof(candidate) == "Instance" and candidate:IsA("Actor") then
            actor = candidate
            break
        end
    end
    if not actor then
        return false
    end

    local sourceSpec = detectBootstrapSource()
    if not sourceSpec then
        warn("[UiLibrary] actor detected but bootstrap source was not resolved; running on current thread.")
        return false
    end

    local payload
    if sourceSpec.Kind == "code" then
        payload = string.format([[
getgenv().__XERO_UI_ACTOR_RUNNING = true
local ok, err = pcall(function()
    loadstring(%q)()
end)
if not ok then
    warn("[UiLibrary] actor bootstrap error:", err)
end
]], sourceSpec.Value)
    else
        payload = string.format([[
getgenv().__XERO_UI_ACTOR_RUNNING = true
getgenv().__XERO_UI_SOURCE_PATH = %q
local ok, err = pcall(function()
    loadstring(readfile(%q))()
end)
if not ok then
    warn("[UiLibrary] actor bootstrap error:", err)
end
]], sourceSpec.Value, sourceSpec.Value)
    end

    local okRun, errRun = pcall(run_on_actor, actor, payload)
    if not okRun then
        warn("[UiLibrary] run_on_actor failed:", errRun)
        return false
    end

    return true
end

if tryBootstrapOnActor() then
    return
end

local function deepCopy(v)
    if type(v) ~= "table" then
        return v
    end
    local out = {}
    for k, sub in pairs(v) do
        out[deepCopy(k)] = deepCopy(sub)
    end
    return out
end

local function valuesEqual(a, b)
    if type(a) ~= type(b) then
        return false
    end
    if type(a) ~= "table" then
        return a == b
    end
    for k, v in pairs(a) do
        if not valuesEqual(v, b[k]) then
            return false
        end
    end
    for k, v in pairs(b) do
        if not valuesEqual(v, a[k]) then
            return false
        end
    end
    return true
end

local function clamp(v, mn, mx)
    if v < mn then
        return mn
    end
    if v > mx then
        return mx
    end
    return v
end

local function normalizeKeyCode(value)
    if typeof(value) == "EnumItem" and value.EnumType == Enum.KeyCode then
        return value
    end
    if type(value) == "string" then
        if value == "" then
            return nil
        end
        local direct = Enum.KeyCode[value]
        if direct then
            return direct
        end
        local lowered = string.lower(value)
        for _, enumItem in ipairs(Enum.KeyCode:GetEnumItems()) do
            if string.lower(enumItem.Name) == lowered then
                return enumItem
            end
        end
    end
    return nil
end

local ERROR_FLASH_COLOR = Color3.fromRGB(232, 104, 122)

local function flashGuiError(flashTarget)
    local target
    local restoreColor

    if typeof(flashTarget) == "Instance" then
        target = flashTarget
    elseif type(flashTarget) == "table" then
        target = flashTarget.Target or flashTarget.Instance
        restoreColor = flashTarget.RestoreColor
    end

    if typeof(target) ~= "Instance" or not target:IsA("GuiObject") then
        return
    end

    restoreColor = restoreColor or target.BackgroundColor3
    local targetGradient = target:FindFirstChildOfClass("UIGradient")
    local restoreGradientColor = targetGradient and targetGradient.Color or nil
    local flashGradientColor = ColorSequence.new(ERROR_FLASH_COLOR)

    TweenService:Create(target, TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        BackgroundColor3 = ERROR_FLASH_COLOR,
    }):Play()
    if targetGradient then
        targetGradient.Color = flashGradientColor
    end

    task.delay(0.14, function()
        if not target or not target.Parent then
            return
        end
        TweenService:Create(target, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            BackgroundColor3 = restoreColor,
        }):Play()
        if targetGradient and targetGradient.Parent == target and restoreGradientColor then
            targetGradient.Color = restoreGradientColor
        end
    end)
end

local function safeCall(fn, flashTarget, ...)
    if type(fn) ~= "function" then
        return true
    end
    local ok, err = pcall(fn, ...)
    if not ok then
        warn("[UiLibrary] callback error:", err)
        flashGuiError(flashTarget)
    end
    return ok, err
end

local function sanitizeName(name)
    local v = tostring(name or "default")
    v = v:gsub("[^%w%-%._ ]", "_")
    v = v:gsub("^%s+", ""):gsub("%s+$", "")
    if v == "" then
        v = "default"
    end
    return v
end

local function randomToken(length)
    local chars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
    local rng = Random.new()
    local out = table.create(length)
    for i = 1, length do
        local idx = rng:NextInteger(1, #chars)
        out[i] = chars:sub(idx, idx)
    end
    return table.concat(out)
end

local function buildRandomUiName(baseName)
    local base = sanitizeName(baseName or UI_NAME_PREFIX):gsub("%s+", "")
    if base == "" then
        base = UI_NAME_PREFIX
    end
    if not base:match("_$") then
        base = base .. "_"
    end
    return base .. randomToken(10)
end

local function cleanupExistingUi(parent, explicitName)
    local active = env[UI_ACTIVE_KEY]
    if typeof(active) == "Instance" and active:IsA("ScreenGui") then
        pcall(function()
            active:Destroy()
        end)
    end
    env[UI_ACTIVE_KEY] = nil

    if typeof(parent) ~= "Instance" then
        return
    end

    for _, child in ipairs(parent:GetChildren()) do
        if child:IsA("ScreenGui") then
            local managed = child:GetAttribute(UI_MANAGED_ATTR) == true
            local legacyNamed = child.Name == "XeroHubUI" or child.Name:sub(1, #UI_NAME_PREFIX) == UI_NAME_PREFIX
            local exactMatch = explicitName and child.Name == explicitName
            if managed or legacyNamed or exactMatch then
                pcall(function()
                    child:Destroy()
                end)
            end
        end
    end
end

local function create(className, props, parent)
    local obj = Instance.new(className)
    if props then
        for k, v in pairs(props) do
            pcall(function()
                obj[k] = v
            end)
        end
    end
    if parent then
        obj.Parent = parent
    end
    return obj
end

local connect

local function corner(parent, r)
    return create("UICorner", { CornerRadius = UDim.new(0, r or 8) }, parent)
end

local PURE_WHITE = Color3.fromRGB(255, 255, 255)

local function isNearlyWhite(color)
    if typeof(color) ~= "Color3" then
        return false
    end
    return color.R >= 0.98 and color.G >= 0.98 and color.B >= 0.98
end

local function stroke(parent, color, tr, thick)
    local nextColor = color or PURE_WHITE
    if isNearlyWhite(nextColor) then
        nextColor = Color3.fromRGB(162, 170, 186)
    end
    return create("UIStroke", {
        Color = nextColor,
        Transparency = tr == nil and 0.85 or tr,
        Thickness = thick or 1,
    }, parent)
end

local function gradient(parent, colors, rotation)
    local keypoints = {}
    local n = #colors
    for i, c in ipairs(colors) do
        table.insert(keypoints, ColorSequenceKeypoint.new((n <= 1) and 0 or ((i - 1) / (n - 1)), c))
    end
    return create("UIGradient", {
        Color = ColorSequence.new(keypoints),
        Rotation = rotation or 0,
    }, parent)
end

local function tween(target, tweenInfo, props)
    local ok, tweenObj = pcall(TweenService.Create, TweenService, target, tweenInfo, props)
    if ok and tweenObj then
        tweenObj:Play()
        return tweenObj
    end
    return nil
end

local function bindHover(guiObject, enterProps, leaveProps, duration)
    if typeof(guiObject) ~= "Instance" or not guiObject:IsA("GuiObject") then
        return
    end
    if not UserInputService.MouseEnabled then
        return
    end
    local d = duration or 0.14
    connect(guiObject.MouseEnter, function()
        tween(guiObject, TweenInfo.new(d, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), enterProps)
    end)
    connect(guiObject.MouseLeave, function()
        tween(guiObject, TweenInfo.new(d, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), leaveProps)
    end)
end

local function guiParent()
    if type(gethui) == "function" then
        local ok, g = pcall(gethui)
        if ok and g then
            return g
        end
    end
    if type(get_hidden_gui) == "function" then
        local ok, g = pcall(get_hidden_gui)
        if ok and g then
            return g
        end
    end
    return CoreGui
end

