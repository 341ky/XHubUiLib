    function window:CloseAllDropdowns(exceptDropdown)
        for _, entry in ipairs(self._dropdownEntries) do
            if entry and entry.Dropdown and entry.Dropdown.IsOpen then
                if exceptDropdown == nil or entry.Dropdown ~= exceptDropdown then
                    if type(entry.Close) == "function" then
                        entry.Close()
                    end
                end
            end
        end
    end

    function window:CloseDropdownsOutside(screenPos)
        for _, entry in ipairs(self._dropdownEntries) do
            if entry and entry.Dropdown and entry.Dropdown.IsOpen then
                local insideHost = pointInGui(entry.Host, screenPos)
                local insidePanel = pointInGui(entry.Panel, screenPos)
                if not insideHost and not insidePanel then
                    if type(entry.Close) == "function" then
                        entry.Close()
                    end
                end
            end
        end
    end

    function window:SelectTab(tab)
        for _, t in ipairs(self.Tabs) do
            local active = (t == tab)
            t.IsActive = active
            t.Page.Visible = active
            local targetBg = active and self.Library.Theme.SurfaceRaised or self.Library.Theme.Surface
            tween(t.Button, TweenInfo.new(0.16, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                BackgroundColor3 = targetBg,
            })
            local label = t.Button:FindFirstChildOfClass("TextLabel")
            if label then
                label.TextColor3 = active and self.Library.Theme.Text or self.Library.Theme.Muted
                label.Font = active and Enum.Font.GothamSemibold or Enum.Font.GothamMedium
            end
            local dot = t.Button:FindFirstChild("TabDot")
            if dot and dot:IsA("Frame") then
                dot.BackgroundColor3 = active and self.Library.Theme.Accent or self.Library.Theme.Muted
            end
            if t.Stroke then
                t.Stroke.Color = active and self.Library.Theme.Accent or self.Library.Theme.StrokeSoft
                t.Stroke.Transparency = active and 0.42 or 0.64
                t.Stroke.Thickness = 1
