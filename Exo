        }, pages)

        create("UIPadding", {
            PaddingLeft = UDim.new(0, self.IsMobile and 0 or 0),
            PaddingRight = UDim.new(0, self.IsMobile and 0 or 0),
            PaddingTop = UDim.new(0, 0),
            PaddingBottom = UDim.new(0, 0),
        }, page)

        local columnsHolder = create("Frame", {
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, 0),
            AutomaticSize = Enum.AutomaticSize.Y,
        }, page)

        local columnCount = self.IsMobile and 1 or 3
        local columnGap = self.IsMobile and 8 or 10
        local columns = {}
        local columnLayouts = {}

        local function updatePageCanvas()
            local maxY = 0
            for _, layoutObj in ipairs(columnLayouts) do
                maxY = math.max(maxY, layoutObj.AbsoluteContentSize.Y)
            end
            page.CanvasSize = UDim2.new(0, 0, 0, maxY + 14)
        end

        local function updateColumnWidths()
            local availableWidth = page.AbsoluteSize.X
            if availableWidth <= 0 then
                return
            end

            local cardWidth
            if #columns == 1 then
                cardWidth = availableWidth
            else
                cardWidth = math.floor((availableWidth - columnGap) / #columns)
            end
            cardWidth = math.max(110, cardWidth)

            local totalWidth = (cardWidth * #columns) + (columnGap * (#columns - 1))
            columnsHolder.Size = UDim2.new(0, totalWidth, 0, 0)
            columnsHolder.Position = UDim2.new(0, 0, 0, 0)

            local x = 0
            for _, column in ipairs(columns) do
                column.Size = UDim2.new(0, cardWidth, 0, 0)
                column.Position = UDim2.new(0, x, 0, 0)
                x += cardWidth + columnGap
            end

            updatePageCanvas()
        end

        for i = 1, columnCount do
            local column = create("Frame", {
                BackgroundTransparency = 1,
                AutomaticSize = Enum.AutomaticSize.Y,
                Size = UDim2.new(0, 120, 0, 0),
                Position = UDim2.new(0, 0, 0, 0),
            }, columnsHolder)

            local colLayout = create("UIListLayout", {
                Padding = UDim.new(0, columnGap),
                SortOrder = Enum.SortOrder.LayoutOrder,
            }, column)

            connect(colLayout:GetPropertyChangedSignal("AbsoluteContentSize"), updatePageCanvas)
            table.insert(columns, column)
            table.insert(columnLayouts, colLayout)
        end

        connect(page:GetPropertyChangedSignal("AbsoluteSize"), updateColumnWidths)
        task.defer(updateColumnWidths)

        local tab = {
            Name = name,
            Window = self,
            Button = button,
            Stroke = tabStroke,
            ActiveStrip = activeStrip,
            Page = page,
            Columns = columns,
            ColumnLayouts = columnLayouts,
            IsActive = false,
            _nextColumn = 1,
            Order = 0,
        }

        connect(button.MouseEnter, function()
            if not tab.IsActive then
                button.BackgroundColor3 = self.Library.Theme.SurfaceAlt
            end
        end)
        connect(button.MouseLeave, function()
            if not tab.IsActive then
                button.BackgroundColor3 = self.Library.Theme.Surface
            end
        end)

        local function nextOrder()
            tab.Order += 1
            return tab.Order
