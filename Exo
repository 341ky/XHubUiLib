                local knobSize = self.Tab.Window.IsMobile and 20 or 18
                local knob = create("Frame", {
                    Size = UDim2.fromOffset(knobSize, knobSize),
                    Position = UDim2.new(0, 2, 0.5, -(knobSize / 2)),
                    BackgroundColor3 = Color3.fromRGB(226, 241, 255),
                    BorderSizePixel = 0,
                }, sw)
                corner(knob, 999)

                local obj = {
                    Type = "Toggle",
                    Flag = flag,
                    Value = false,
                    Keybind = nil,
                    KeybindValue = "",
                    Callback = options.Callback,
                    KeybindChanged = options.KeybindChanged,
                    KeybindPressed = options.KeybindPressed,
                    _listeningKeybind = false,
                    _listeners = {},
                    _keybindListeners = {},
                    _keyPressedListeners = {},
                }

                function obj:OnChanged(fn)
                    if type(fn) == "function" then
                        table.insert(self._listeners, fn)
                    end
                    return self
                end

                function obj:OnKeybindChanged(fn)
                    if type(fn) == "function" then
                        table.insert(self._keybindListeners, fn)
                    end
                    return self
                end

                function obj:OnKeyPressed(fn)
                    if type(fn) == "function" then
                        table.insert(self._keyPressedListeners, fn)
                    end
                    return self
                end

                local function updateBindButtonText()
                    if not bindButton then
                        return
                    end
                    if obj._listeningKeybind then
                        bindButton.Text = "Press key..."
                    elseif obj.KeybindValue == "" then
                        bindButton.Text = "None"
                    else
                        bindButton.Text = obj.KeybindValue
                    end
                end

                function obj:SetKeybind(value, silent)
                    local keycode = normalizeKeyCode(value)
                    local keyName = keycode and keycode.Name or ""
                    if self.KeybindValue == keyName then
                        updateBindButtonText()
                        return
                    end

                    self.Keybind = keycode
                    self.KeybindValue = keyName
                    updateBindButtonText()

                    if not silent then
                        safeCall(self.KeybindChanged, bindButton or sw, keyName)
                        for _, listener in ipairs(self._keybindListeners) do
                            safeCall(listener, bindButton or sw, keyName)
                        end
                    end
                end

                function obj:SetValue(v, silent)
                    v = v == true
                    if self.Value == v then
                        return
                    end
                    self.Value = v

                    local trackWidth = (sw.AbsoluteSize.X > 0) and sw.AbsoluteSize.X or switchWidth
                    local knobWidth = (knob.AbsoluteSize.X > 0) and knob.AbsoluteSize.X or knobSize
                    local targetX = v and (trackWidth - knobWidth - 2) or 2
                    local bg = v and section.Tab.Window.Library.Theme.AccentDark
                        or section.Tab.Window.Library.Theme.SurfaceDeep

                    TweenService:Create(sw, TweenInfo.new(0.16, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                        BackgroundColor3 = bg,
                    }):Play()
                    TweenService:Create(knob, TweenInfo.new(0.16, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                        Position = UDim2.new(0, targetX, 0.5, -(knobSize / 2)),
                    }):Play()

                    section.Tab.Window.Library:_flagChanged(flag, v, silent)
                    if not silent then
                        local flashState = {
                            Target = sw,
                            RestoreColor = bg,
                        }
                        safeCall(self.Callback, flashState, v)
                        for _, listener in ipairs(self._listeners) do
                            safeCall(listener, flashState, v)
                        end
                    end
                end

                connect(sw.MouseButton1Click, function()
                    obj:SetValue(not obj.Value, false)
                end)

                if bindButton then
                    connect(bindButton.MouseButton1Click, function()
                        obj._listeningKeybind = true
                        updateBindButtonText()
                    end)
                end

                connect(UserInputService.InputBegan, function(input, gp)
                    if gp then
                        return
                    end
                    if input.UserInputType ~= Enum.UserInputType.Keyboard then
                        return
                    end

                    if obj._listeningKeybind then
                        obj._listeningKeybind = false
                        if input.KeyCode == Enum.KeyCode.Escape then
                            if options.EscapeClearsKeybind == true then
                                obj:SetKeybind(nil, false)
                            else
                                updateBindButtonText()
                            end
                            return
                        end
                        obj:SetKeybind(input.KeyCode, false)
                        return
                    end

                    if obj.Keybind and input.KeyCode == obj.Keybind then
                        obj:SetValue(not obj.Value, false)
                        safeCall(obj.KeybindPressed, bindButton or sw, obj.KeybindValue, obj.Value)
                        for _, listener in ipairs(obj._keyPressedListeners) do
                            safeCall(listener, bindButton or sw, obj.KeybindValue, obj.Value)
                        end
                    end
                end)

                section.Tab.Window.Library.Toggles[flag] = obj
                section.Tab.Window.Library._controls[flag] = obj

                local initial, auto = section.Tab.Window.Library:_initialValue(flag, options.Default == true)
                local silentInit = not (auto and section.Tab.Window.Library.Config.FireCallbacksOnLoad)
                obj:SetValue(initial, silentInit)

                local initialBind, autoBind = section.Tab.Window.Library:_initialToggleBind(flag, options.Keybind or "")
                local silentBindInit = not (autoBind and section.Tab.Window.Library.Config.FireCallbacksOnLoad)
                obj:SetKeybind(initialBind, silentBindInit)
                updateBindButtonText()

                return obj
            end
            function section:AddInput(flag, options)
