            function section:AddSlider(flag, options)
                options = options or {}

                local minValue = tonumber(options.Min)
                local maxValue = tonumber(options.Max)
                if minValue == nil then
                    minValue = 0
                end
                if maxValue == nil then
                    maxValue = 100
                end
                if maxValue < minValue then
                    minValue, maxValue = maxValue, minValue
                end

                local step = tonumber(options.Step) or 1
                if step <= 0 then
                    step = 1
                end

                local decimals = tonumber(options.Decimals)
                if decimals == nil then
                    decimals = (step < 1) and 2 or 0
                end
                decimals = math.max(0, math.floor(decimals))
                local suffix = tostring(options.Suffix or "")

                local host = shell(self.Tab.Window.IsMobile and 62 or 58)

                create("TextLabel", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, -70, 0, 18),
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Text = tostring(options.Text or flag),
                    TextColor3 = self.Tab.Window.Library.Theme.Text,
                    Font = Enum.Font.GothamSemibold,
                    TextSize = self.Tab.Window.IsMobile and 13 or 12,
                }, host)

                local valueLabel = create("TextLabel", {
                    BackgroundTransparency = 1,
                    Position = UDim2.new(1, -68, 0, 0),
                    Size = UDim2.new(0, 68, 0, 18),
                    TextXAlignment = Enum.TextXAlignment.Right,
                    Text = "",
                    TextColor3 = self.Tab.Window.Library.Theme.Muted,
                    Font = Enum.Font.GothamSemibold,
                    TextSize = self.Tab.Window.IsMobile and 13 or 12,
                }, host)

                local bar = create("Frame", {
                    Position = UDim2.new(0, 0, 0, 28),
                    Size = UDim2.new(1, 0, 0, self.Tab.Window.IsMobile and 14 or 12),
                    BackgroundColor3 = self.Tab.Window.Library.Theme.SurfaceDeep,
                    BorderSizePixel = 0,
                }, host)
                corner(bar, 999)
                stroke(bar, self.Tab.Window.Library.Theme.StrokeSoft, 0.56, 1)

                local fill = create("Frame", {
                    Size = UDim2.new(0, 0, 1, 0),
                    BackgroundColor3 = self.Tab.Window.Library.Theme.Accent,
                    BorderSizePixel = 0,
                }, bar)
                corner(fill, 999)
                gradient(fill, {
                    self.Tab.Window.Library.Theme.AccentDark,
                    self.Tab.Window.Library.Theme.Accent,
                    Color3.fromRGB(242, 244, 248),
                }, 0)

                local knobSize = self.Tab.Window.IsMobile and 16 or 14
                local knob = create("Frame", {
                    AnchorPoint = Vector2.new(0.5, 0.5),
                    Size = UDim2.fromOffset(knobSize, knobSize),
                    Position = UDim2.new(0, 0, 0.5, 0),
                    BackgroundColor3 = Color3.fromRGB(230, 243, 255),
                    BorderSizePixel = 0,
                }, bar)
                corner(knob, 999)

                local function quantize(value)
                    local stepped = minValue + (math.floor(((value - minValue) / step) + 0.5) * step)
                    stepped = clamp(stepped, minValue, maxValue)
                    local factor = 10 ^ decimals
                    stepped = math.floor((stepped * factor) + 0.5) / factor
                    return stepped
                end

                local function valueToPercent(value)
                    if maxValue == minValue then
                        return 0
                    end
                    return clamp((value - minValue) / (maxValue - minValue), 0, 1)
                end

                local obj = {
                    Type = "Slider",
                    Flag = flag,
                    Value = minValue,
                    Min = minValue,
                    Max = maxValue,
                    Step = step,
                    Callback = options.Callback,
                    _listeners = {},
                }

                function obj:OnChanged(fn)
                    if type(fn) == "function" then
                        table.insert(self._listeners, fn)
                    end
                    return self
                end

                function obj:SetValue(v, silent)
                    local nextValue = quantize(tonumber(v) or minValue)
                    if valuesEqual(self.Value, nextValue) then
                        return
                    end

                    self.Value = nextValue
                    local percent = valueToPercent(nextValue)
                    fill.Size = UDim2.new(percent, 0, 1, 0)
                    knob.Position = UDim2.new(percent, 0, 0.5, 0)

                    local textValue = string.format("%." .. tostring(decimals) .. "f", nextValue)
                    valueLabel.Text = textValue .. suffix
                    section.Tab.Window.Library:_flagChanged(flag, nextValue, silent)

                    if not silent then
                        safeCall(self.Callback, bar, nextValue)
                        for _, listener in ipairs(self._listeners) do
                            safeCall(listener, bar, nextValue)
                        end
                    end
                end

                local dragging = false
                local function setFromScreenX(screenX)
                    local x = screenX - bar.AbsolutePosition.X
                    local width = math.max(1, bar.AbsoluteSize.X)
                    local percent = clamp(x / width, 0, 1)
                    local raw = minValue + ((maxValue - minValue) * percent)
                    obj:SetValue(raw, false)
                end

                connect(bar.InputBegan, function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        dragging = true
                        setFromScreenX(input.Position.X)
                    end
                end)

                connect(bar.InputEnded, function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        dragging = false
                    end
                end)

                connect(UserInputService.InputChanged, function(input)
                    if not dragging then
                        return
                    end
                    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
                        setFromScreenX(input.Position.X)
                    end
                end)

                connect(UserInputService.InputEnded, function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        dragging = false
                    end
                end)

                section.Tab.Window.Library.Options[flag] = obj
                section.Tab.Window.Library._controls[flag] = obj

                local def = options.Default
                if def == nil then
                    def = minValue
                end
                local initial, auto = section.Tab.Window.Library:_initialValue(flag, def)
                local silentInit = not (auto and section.Tab.Window.Library.Config.FireCallbacksOnLoad)
                obj:SetValue(initial, silentInit)

                return obj
            end

