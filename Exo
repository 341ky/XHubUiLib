                connect(UserInputService.InputBegan, function(input, gp)
                    if gp then
                        return
                    end
                    if input.UserInputType ~= Enum.UserInputType.Keyboard then
                        return
                    end

                    if obj._listening then
                        obj._listening = false
                        if input.KeyCode == Enum.KeyCode.Escape then
                            updateBindText()
                            return
                        end
                        obj:SetValue(input.KeyCode, false)
                        return
                    end

                    if obj.KeyCode and input.KeyCode == obj.KeyCode then
                        local keyName = obj.Value
                        safeCall(obj.Pressed, bindButton, keyName)
                        for _, listener in ipairs(obj._pressListeners) do
                            safeCall(listener, bindButton, keyName)
                        end
                    end
