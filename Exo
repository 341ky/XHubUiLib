                }, host)
                corner(header, 8)
                stroke(header, self.Tab.Window.Library.Theme.StrokeSoft, 0.56, 1)
                bindHover(header, {
                    BackgroundColor3 = self.Tab.Window.Library.Theme.SurfaceAlt,
                }, {
                    BackgroundColor3 = self.Tab.Window.Library.Theme.SurfaceDeep,
                }, 0.12)

                create("TextLabel", {
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 10, 0, 0),
                    Size = UDim2.new(0.45, -6, 1, 0),
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Text = tostring(options.Text or flag),
                    TextColor3 = self.Tab.Window.Library.Theme.Text,
                    Font = Enum.Font.GothamSemibold,
                    TextSize = self.Tab.Window.IsMobile and 13 or 12,
                    ZIndex = 5,
                }, header)

                local arrow = create("TextLabel", {
                    BackgroundTransparency = 1,
                    Position = UDim2.new(1, -16, 0, 0),
                    Size = UDim2.new(0, 16, 1, 0),
                    Text = ">",
                    TextColor3 = self.Tab.Window.Library.Theme.Muted,
                    Font = Enum.Font.GothamBold,
                    TextSize = self.Tab.Window.IsMobile and 15 or 14,
                    ZIndex = 5,
                }, header)

                local selectedLabel = create("TextLabel", {
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0.45, 2, 0, 0),
                    Size = UDim2.new(0.55, -28, 1, 0),
                    TextXAlignment = Enum.TextXAlignment.Right,
                    Text = tostring(options.Placeholder or "Select..."),
                    TextColor3 = self.Tab.Window.Library.Theme.Muted,
                    Font = Enum.Font.GothamMedium,
                    TextSize = self.Tab.Window.IsMobile and 13 or 12,
                    TextTruncate = Enum.TextTruncate.AtEnd,
                    ZIndex = 5,
                }, header)

                local panel = create("Frame", {
                    Position = UDim2.new(0, 8, 0, headerH + 6),
                    Size = UDim2.new(1, -16, 0, 0),
                    BackgroundColor3 = self.Tab.Window.Library.Theme.SurfaceDeep,
                    BorderSizePixel = 0,
                    ClipsDescendants = true,
                    ZIndex = 7,
                }, host)
                corner(panel, 8)
                stroke(panel, self.Tab.Window.Library.Theme.Stroke, 0.46, 1)
                gradient(panel, {
                    self.Tab.Window.Library.Theme.SurfaceDeep,
                    self.Tab.Window.Library.Theme.SurfaceAlt,
                }, 90)

                create("UIPadding", {
                    PaddingLeft = UDim.new(0, 6),
                    PaddingRight = UDim.new(0, 6),
                    PaddingTop = UDim.new(0, 6),
                    PaddingBottom = UDim.new(0, 6),
                }, panel)

                local searchBox
                if searchable then
                    searchBox = create("TextBox", {
                        Size = UDim2.new(1, 0, 0, self.Tab.Window.IsMobile and 30 or 28),
                        BackgroundColor3 = self.Tab.Window.Library.Theme.Surface,
                        BorderSizePixel = 0,
                        Text = "",
                        PlaceholderText = "Search...",
                        TextColor3 = self.Tab.Window.Library.Theme.Text,
                        PlaceholderColor3 = self.Tab.Window.Library.Theme.Muted,
                        Font = Enum.Font.GothamMedium,
                        TextSize = self.Tab.Window.IsMobile and 13 or 12,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        ZIndex = 8,
                    }, panel)
                    corner(searchBox, 7)
                    stroke(searchBox, self.Tab.Window.Library.Theme.StrokeSoft, 0.56, 1)
                end

                local list = create("ScrollingFrame", {
                    Position = UDim2.new(0, 0, 0, searchable and (self.Tab.Window.IsMobile and 34 or 32) or 0),
                    Size = UDim2.new(1, 0, 1, searchable and -(self.Tab.Window.IsMobile and 34 or 32) or 0),
                    BackgroundTransparency = 1,
                    BorderSizePixel = 0,
                    CanvasSize = UDim2.new(),
                    ScrollBarThickness = self.Tab.Window.IsMobile and 4 or 5,
                    ScrollBarImageColor3 = self.Tab.Window.Library.Theme.StrokeSoft,
                    ZIndex = 8,
                }, panel)

                local listLayout = create("UIListLayout", {
                    SortOrder = Enum.SortOrder.LayoutOrder,
                    Padding = UDim.new(0, 4),
                }, list)

                local noneLabel = create("TextLabel", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, -4, 0, rowH),
                    Text = "No results",
                    TextColor3 = self.Tab.Window.Library.Theme.Muted,
                    Font = Enum.Font.GothamMedium,
                    TextSize = self.Tab.Window.IsMobile and 13 or 12,
                    Visible = false,
                    LayoutOrder = 99999,
                    ZIndex = 8,
                }, list)

                local obj = {
                    Type = "Dropdown",
                    Flag = flag,
                    Values = values,
                    Value = multi and {} or nil,
                    Multi = multi,
                    Callback = options.Callback,
                    IsOpen = false,
                    _listeners = {},
                }

                local rows = {}

                local function normalizeMulti(v)
                    local out = {}
                    if type(v) ~= "table" then
                        return out
                    end
                    if #v > 0 then
                        for _, entry in ipairs(v) do
                            out[entry] = true
                        end
                    else
                        for key, enabled in pairs(v) do
                            if enabled then
                                out[key] = true
                            end
                        end
                    end
                    return out
                end

                local function summary()
                    if obj.Multi then
                        local picked = orderedSelected(obj.Values, obj.Value)
                        if #picked == 0 then
                            return tostring(options.Placeholder or "None")
                        end
                        if #picked <= 2 then
                            local names = {}
                            for _, x in ipairs(picked) do
                                table.insert(names, tostring(x))
                            end
                            return table.concat(names, ", ")
                        end
                        return string.format("%s, %s +%d", tostring(picked[1]), tostring(picked[2]), #picked - 2)
                    end
                    if obj.Value == nil then
                        return tostring(options.Placeholder or "Select...")
                    end
                    return tostring(obj.Value)
                end

                local function updateSummary()
                    selectedLabel.Text = summary()
                    if obj.Multi then
                        selectedLabel.TextColor3 = (#orderedSelected(obj.Values, obj.Value) > 0)
                            and section.Tab.Window.Library.Theme.Text
                            or section.Tab.Window.Library.Theme.Muted
                    else
                        selectedLabel.TextColor3 = (obj.Value ~= nil)
                            and section.Tab.Window.Library.Theme.Text
                            or section.Tab.Window.Library.Theme.Muted
                    end
                end

                local function updateMarks()
                    for _, row in ipairs(rows) do
                        local selected = obj.Multi and obj.Value[row.Value] or (obj.Value == row.Value)
                        row.Mark.BackgroundColor3 = selected and section.Tab.Window.Library.Theme.Success
                            or section.Tab.Window.Library.Theme.Muted
                        row.Mark.BackgroundTransparency = selected and 0 or 0.8
                        row.Button.BackgroundTransparency = selected and 0.18 or 0.62
                        row.Button.BackgroundColor3 = selected and section.Tab.Window.Library.Theme.SurfaceAlt
                            or section.Tab.Window.Library.Theme.Surface
                    end
                end

                local function visibleCount()
                    local c = 0
                    for _, row in ipairs(rows) do
                        if row.Button.Visible then
                            c += 1
                        end
                    end
                    return c
                end

                local function updateCanvas()
                    list.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 4)
                end

                local function panelHeight()
                    local c = visibleCount()
                    noneLabel.Visible = (c == 0)
                    local listH = (c > 0) and (c * rowH + (c - 1) * 4 + 4) or rowH
                    listH = math.min(listH, maxH)
                    local searchH = searchable and (self.Tab.Window.IsMobile and 34 or 32) or 0
                    return searchH + listH + 8
                end

                local function setOpen(state)
                    if obj.IsOpen == state then
                        return
                    end
                    if state then
                        section.Tab.Window:CloseAllDropdowns(obj)
                    end
                    obj.IsOpen = state
                    arrow.Text = state and "v" or ">"

                    local h = state and panelHeight() or 0
                    local hostH = headerH + ((state and h > 0) and (h + 8) or 0)

                    TweenService:Create(panel, TweenInfo.new(0.16, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                        Size = UDim2.new(1, -16, 0, h),
                    }):Play()
                    TweenService:Create(host, TweenInfo.new(0.16, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                        Size = UDim2.new(1, 0, 0, hostH),
                    }):Play()
                end

                local function applyFilter(text)
                    local query = string.lower(tostring(text or ""))
                    for _, row in ipairs(rows) do
                        local ok = (query == "") or (string.find(string.lower(tostring(row.Value)), query, 1, true) ~= nil)
                        row.Button.Visible = ok
                    end
                    noneLabel.Visible = (visibleCount() == 0)
                    updateCanvas()
                    if obj.IsOpen then
                        local h = panelHeight()
                        panel.Size = UDim2.new(1, -16, 0, h)
                        host.Size = UDim2.new(1, 0, 0, headerH + h + 8)
                    end
                end

                local function rebuild()
                    for _, row in ipairs(rows) do
                        row.Button:Destroy()
                    end
                    table.clear(rows)

                    for i, value in ipairs(obj.Values) do
                        local button = create("TextButton", {
                            Text = "",
                            AutoButtonColor = false,
                            Size = UDim2.new(1, -2, 0, rowH),
                            BackgroundColor3 = section.Tab.Window.Library.Theme.Surface,
                            BackgroundTransparency = 0.62,
                            BorderSizePixel = 0,
                            LayoutOrder = i,
                            ZIndex = 8,
                        }, list)
                        corner(button, 6)
                        stroke(button, section.Tab.Window.Library.Theme.StrokeSoft, 0.66, 1)

                        local mark = create("Frame", {
                            Size = UDim2.fromOffset(12, 12),
                            Position = UDim2.new(0, 8, 0.5, -6),
                            BackgroundColor3 = section.Tab.Window.Library.Theme.Muted,
                            BackgroundTransparency = 0.8,
                            BorderSizePixel = 0,
                            ZIndex = 9,
                        }, button)
                        corner(mark, 999)

                        create("TextLabel", {
                            BackgroundTransparency = 1,
                            Position = UDim2.new(0, 22, 0, 0),
                            Size = UDim2.new(1, -26, 1, 0),
                            TextXAlignment = Enum.TextXAlignment.Left,
                            Text = tostring(value),
                            TextColor3 = section.Tab.Window.Library.Theme.Text,
                            Font = Enum.Font.GothamMedium,
                            TextSize = section.Tab.Window.IsMobile and 13 or 12,
                            TextTruncate = Enum.TextTruncate.AtEnd,
                            ZIndex = 9,
                        }, button)

                        table.insert(rows, {
                            Value = value,
                            Button = button,
                            Mark = mark,
                        })

                        connect(button.MouseButton1Click, function()
                            if obj.Multi then
                                local nextV = deepCopy(obj.Value)
                                nextV[value] = not nextV[value]
                                obj:SetValue(nextV, false)
                            else
                                obj:SetValue(value, false)
                                setOpen(false)
                            end
                        end)
                    end

                    updateCanvas()
                    updateMarks()
                    applyFilter(searchBox and searchBox.Text or "")
                end

                function obj:OnChanged(fn)
                    if type(fn) == "function" then
                        table.insert(self._listeners, fn)
                    end
                    return self
                end

                function obj:SetValue(v, silent)
                    local nextV
                    if self.Multi then
                        nextV = normalizeMulti(v)
                        local filtered = {}
                        for _, item in ipairs(self.Values) do
                            if nextV[item] then
                                filtered[item] = true
                            end
                        end
                        nextV = filtered
                    else
                        nextV = v
                        if nextV ~= nil and not contains(self.Values, nextV) then
                            nextV = nil
                        end
                    end

                    if valuesEqual(self.Value, nextV) then
                        return
                    end

                    self.Value = deepCopy(nextV)
                    updateSummary()
                    updateMarks()
                    section.Tab.Window.Library:_flagChanged(flag, self.Value, silent)

                    if not silent then
                        local send = self.Multi and deepCopy(self.Value) or self.Value
                        safeCall(self.Callback, nil, send)
                        for _, listener in ipairs(self._listeners) do
                            safeCall(listener, nil, send)
                        end
                    end
                end

                function obj:SetValues(newValues, keepSelection)
                    self.Values = deepCopy(newValues or {})
                    if self.Multi then
                        if keepSelection then
                            local keep = {}
                            for _, item in ipairs(self.Values) do
                                if self.Value[item] then
                                    keep[item] = true
                                end
                            end
                            self.Value = keep
                        else
                            self.Value = {}
                        end
                    else
                        if not keepSelection or not contains(self.Values, self.Value) then
                            self.Value = options.AllowNone and nil or self.Values[1]
                        end
                    end
                    rebuild()
                    updateSummary()
                    updateMarks()
                    section.Tab.Window.Library:_flagChanged(flag, self.Value, true)
                end

                connect(header.MouseButton1Click, function()
                    setOpen(not obj.IsOpen)
                end)

                if searchBox then
                    connect(searchBox:GetPropertyChangedSignal("Text"), function()
                        applyFilter(searchBox.Text)
                    end)
                end

                connect(listLayout:GetPropertyChangedSignal("AbsoluteContentSize"), updateCanvas)
                section.Tab.Window:RegisterDropdown({
                    Dropdown = obj,
                    Host = host,
                    Panel = panel,
                    Close = function()
                        setOpen(false)
                    end,
                })

                rebuild()

                section.Tab.Window.Library.Options[flag] = obj
                section.Tab.Window.Library._controls[flag] = obj

                local def
                if multi then
                    def = options.Default or {}
                else
                    if options.Default ~= nil then
                        def = options.Default
                    else
                        def = options.AllowNone and nil or values[1]
                    end
                end

                local initial, auto = section.Tab.Window.Library:_initialValue(flag, def)
                local silentInit = not (auto and section.Tab.Window.Library.Config.FireCallbacksOnLoad)
                obj:SetValue(initial, silentInit)
                updateSummary()
                setOpen(false)

                return obj
            end

            function section:AddMultiDropdown(flag, options)
                options = options or {}
                options.Multi = true
                return self:AddDropdown(flag, options)
            end

            return section
        end

        connect(button.MouseButton1Click, function()
            window:SelectTab(tab)
        end)

        table.insert(self.Tabs, tab)
        if #self.Tabs == 1 then
            self:SelectTab(tab)
        end

        updateTabCanvas()
        return tab
    end

    function window:AddConfigTab(tabName)
        local settingsTab = self:AddTab(tabName or "UI Settings")
        local configSection = settingsTab:AddSection("Config Profiles")
        local behaviorSection = settingsTab:AddSection("Config Behavior")

        local function buildProfileList()
            local seen = {}
            local out = {}

            local function addProfile(name)
                if type(name) ~= "string" then
                    return
                end
                local clean = sanitizeName(name)
                if clean == "" or seen[clean] then
                    return
                end
                seen[clean] = true
                table.insert(out, clean)
            end

            for _, name in ipairs(self.PreloadedProfiles or {}) do
                addProfile(name)
            end
            addProfile(self.Library.Config.Profile)
            for _, name in ipairs(self.Library:ListConfigs()) do
                addProfile(name)
            end

            table.sort(out)
            return out
        end

        local profileInput = configSection:AddInput("__xero_ui_profile_input", {
            Text = "Profile Name",
            Default = self.Library.Config.Profile,
            Placeholder = "default",
        })

        local profilesDropdown = configSection:AddDropdown("__xero_ui_profiles_list", {
            Text = "Saved Profiles",
            Values = buildProfileList(),
            Search = true,
            AllowNone = true,
            Placeholder = "None",
        })

        local function refreshProfiles(keepSelection)
            local selected = profilesDropdown.Value
            profilesDropdown:SetValues(buildProfileList(), keepSelection ~= false)
            if keepSelection and selected ~= nil then
                profilesDropdown:SetValue(selected, true)
            end
        end

        configSection:AddButton("Refresh Profiles", function()
            refreshProfiles(false)
            self.Library:Notify("Profile list refreshed.", 2)
        end)

        configSection:AddButton("Use Typed Profile", function()
            local typed = sanitizeName(profileInput.Value)
            if typed == "" then
                typed = "default"
            end
            self.Library.Config.Profile = typed
            local exists = false
            for _, name in ipairs(self.PreloadedProfiles) do
                if name == typed then
                    exists = true
                    break
                end
            end
            if not exists then
                table.insert(self.PreloadedProfiles, typed)
            end
            profileInput:SetValue(typed, true)
            profilesDropdown:SetValue(typed, true)
            self.Library:Notify("Active profile: " .. typed, 2)
        end)

        configSection:AddButton("Save Active Profile", function()
            local typed = sanitizeName(profileInput.Value)
            if typed ~= "" then
                self.Library.Config.Profile = typed
            end
            local ok, err = self.Library:SaveConfig(self.Library.Config.Profile)
            if not ok then
                warn("[UiLibrary] save config error:", err)
                self.Library:Notify("Save failed: " .. tostring(err), 3)
                return
            end
            refreshProfiles(true)
            profilesDropdown:SetValue(self.Library.Config.Profile, true)
            self.Library:Notify("Saved profile: " .. self.Library.Config.Profile, 2)
        end)

        configSection:AddButton("Load Selected Profile", function()
            local selected = profilesDropdown.Value
            if selected == nil or selected == "" then
                selected = sanitizeName(profileInput.Value)
            end
            if selected == nil or selected == "" then
                self.Library:Notify("No profile selected.", 2)
                return
            end

            local ok, err = self.Library:LoadConfig(selected, false)
            if not ok then
                warn("[UiLibrary] load config error:", err)
                self.Library:Notify("Load failed: " .. tostring(err), 3)
                return
            end
            self.Library.Config.Profile = selected
            profileInput:SetValue(selected, true)
            profilesDropdown:SetValue(selected, true)
        end)

        configSection:AddButton("Delete Selected Profile", function()
            local selected = profilesDropdown.Value
            if selected == nil or selected == "" then
                selected = sanitizeName(profileInput.Value)
            end
            if selected == nil or selected == "" then
                self.Library:Notify("No profile selected.", 2)
                return
            end

            local ok, err = self.Library:DeleteConfig(selected)
            if not ok then
                warn("[UiLibrary] delete config error:", err)
                self.Library:Notify("Delete failed: " .. tostring(err), 3)
                return
            end

            refreshProfiles(false)
            self.Library:Notify("Deleted profile: " .. selected, 2)
        end)

        behaviorSection:AddToggle("__xero_ui_cfg_autosave", {
            Text = "Auto Save",
            Default = self.Library.Config.AutoSave,
            Callback = function(v)
                self.Library.Config.AutoSave = v == true
            end,
        })

        behaviorSection:AddToggle("__xero_ui_cfg_autoload", {
            Text = "Auto Load Next Startup",
            Default = self.Library.Config.AutoLoad,
            Callback = function(v)
                self.Library.Config.AutoLoad = v == true
            end,
        })

        behaviorSection:AddToggle("__xero_ui_cfg_firecallbacks", {
            Text = "Run callbacks on config load",
            Default = self.Library.Config.FireCallbacksOnLoad,
            Callback = function(v)
                self.Library.Config.FireCallbacksOnLoad = v == true
            end,
        })

        behaviorSection:AddInput("__xero_ui_cfg_autosave_delay", {
            Text = "Auto Save Delay (sec)",
            Default = self.Library.Config.AutoSaveDelay,
            Numeric = true,
            Callback = function(v)
                self.Library.Config.AutoSaveDelay = clamp(tonumber(v) or self.Library.Config.AutoSaveDelay, 0.05, 10)
            end,
        })

        behaviorSection:AddButton("Save Current Theme+Config", function()
            local ok, err = self.Library:SaveConfig(self.Library.Config.Profile)
            if not ok then
                warn("[UiLibrary] save config error:", err)
                self.Library:Notify("Save failed: " .. tostring(err), 3)
                return
            end
            self.Library:Notify("Saved profile: " .. self.Library.Config.Profile, 2)
        end)

        behaviorSection:AddButton("Unload UI", function()
            self:Destroy()
        end)

        return settingsTab
    end

    if opts.IncludeConfigTab ~= false then
        window:AddConfigTab(opts.ConfigTabName)
    end

    self._window = window

    if self._autoloadFlags then
        self:Notify("Auto-loaded profile: " .. tostring(self.Config.Profile), 3)
    end

    return window
end

Library.Flag = {}

function Library.Flag:Get(...)
    return Library:GetFlags(...)
end

function Library.Flag:IsEnabled(flag)
    return Library:IsEnabled(flag)
end

env.Flag = Library.Flag
env.UiLibrary = Library
if env.__XERO_UI_ACTOR_RUNNING == true then
    env.__XERO_UI_ACTOR_RUNNING = nil
end

return Library
